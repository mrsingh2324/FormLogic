# FormLogic AI — Environment Variables (Python/FastAPI backend)
# Copy to .env and fill in real values. Never commit .env to git.

# ─── Required (all environments) ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/formlogic
JWT_SECRET=your-64-char-random-hex-string-minimum-32-chars-required
JWT_REFRESH_SECRET=another-64-char-random-hex-string-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-gmail-app-password
APP_URL=https://formlogic.ai

# ─── Required in production ────────────────────────────────────────────────────
GCS_BUCKET_NAME=formlogic-uploads
GCS_PROJECT_ID=your-gcp-project-id
# Leave blank on GCP — uses Application Default Credentials
GOOGLE_APPLICATION_CREDENTIALS=
REDIS_URL=redis://localhost:6379/0

# ─── Optional ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID_IOS=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=xxx.apps.googleusercontent.com
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-secret
PORT=8080
NODE_ENV=development
LOG_LEVEL=INFO
CORS_ORIGIN=http://localhost:3000,https://formlogic.ai
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
